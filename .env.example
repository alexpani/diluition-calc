# Configurazione deploy verso il container LXC (Proxmox).
# Copia questo file in .env e compila i valori reali.
# Il file .env e' ignorato da git.

# --- Target SSH del container LXC ---
LXC_SSH_HOST=192.168.1.50
LXC_SSH_USER=deploy
LXC_SSH_PORT=22

# --- Percorsi lato server ---
LXC_WEB_ROOT=/var/www/calcolo-diluizioni

# --- Versione PHP installata nel container (usata per reload php-fpm) ---
# Debian 13 = 8.4, Debian 12 = 8.2
LXC_PHP_VERSION=8.4
